<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    tools:context="com.example.laboratorio0401.MainActivity">

    <DatePicker
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/datePicker"
        android:layout_marginTop="30dp"
        android:calendarViewShown="false"
        android:spinnersShown="false"
        android:datePickerMode="spinner">
    </DatePicker>
<!--    se agregó un marginTop de 30dp para que no este al bordes de la pantalla
        (en la practica no exitia el marginTop)-->


    <TimePicker
        android:id="@+id/timePicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:timePickerMode="spinner"></TimePicker>

    <Button
        android:id="@+id/btnConfigurar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="onClick"
        android:text="Hora:"
        android:textSize="9sp"
        android:layout_marginTop="30dp"/>
<!--    en la practica el botón estaba arriba, se cambió de lugar a la arte inferior-->
    <Button
        android:id="@+id/btnConfigurarFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="onClickFecha"
        android:text="Fecha:"
        android:textSize="9sp"
        android:layout_marginTop="15dp"/>
<!--    se añade el boton para mostrar la fecha seleccionada por el usuario-->
</LinearLayout>